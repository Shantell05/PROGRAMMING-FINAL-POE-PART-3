<Window x:Class="CybersecurityChatbotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛡️ Cybersecurity Awareness Bot - Part 3" 
        Height="850" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        ResizeMode="CanResize"
        MinHeight="700" MinWidth="900">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- LEFT PANEL - Chat Section -->
        <Border Grid.Column="0" Grid.RowSpan="3" Background="#1A1A1A" CornerRadius="10" Padding="10" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ASCII Art Header -->
                <Border Grid.Row="0" Background="#0A2E5C" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" MaxHeight="120">
                        <TextBlock x:Name="AsciiArtTextBlock" FontFamily="Consolas" FontSize="8" Foreground="#00D4FF" TextWrapping="NoWrap"/>
                    </ScrollViewer>
                </Border>

                <!-- Status Bar -->
                <Border Grid.Row="1" Background="#2D2D2D" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="StatusText" Text="✅ Ready" Foreground="#51CF66" FontSize="11" VerticalAlignment="Center"/>

                        <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="12" Padding="8,3" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="SentimentEmoji" Text="😐" FontSize="12"/>
                                <TextBlock x:Name="SentimentText" Text="Neutral" Foreground="#888888" FontSize="10" Margin="3,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <Button x:Name="StatsButton" Grid.Column="2" Content="📊" Width="35" Height="28" Margin="2" Click="StatsButton_Click" Background="#0A2E5C" Foreground="White" BorderBrush="#00D4FF" BorderThickness="1" Cursor="Hand"/>
                        <Button x:Name="LogButton" Grid.Column="3" Content="📋" Width="35" Height="28" Margin="2" Click="LogButton_Click" Background="#1A5F7A" Foreground="White" BorderBrush="#00D4FF" BorderThickness="1" Cursor="Hand"/>
                        <Button x:Name="ExitButton" Grid.Column="4" Content="✕" Width="35" Height="28" Margin="2" Click="ExitButton_Click" Background="#8B0000" Foreground="White" BorderBrush="#FF4444" BorderThickness="1" Cursor="Hand"/>
                    </Grid>
                </Border>

                <!-- Name Input Panel -->
                <Border x:Name="NameInputPanel" Grid.Row="2" Background="#0A2E5C" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="👤 Name:" Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="NameTextBox" Grid.Column="1" Background="#1E1E1E" Foreground="White" BorderBrush="#00D4FF" BorderThickness="1" Padding="10" FontSize="13" VerticalContentAlignment="Center"/>
                        <Button x:Name="SaveNameButton" Grid.Column="2" Content="🚀 Start" Width="80" Height="35" Margin="10,0,0,0" Click="SaveNameButton_Click" Background="#1A5F7A" Foreground="White" BorderBrush="#00D4FF" BorderThickness="1" Cursor="Hand"/>
                    </Grid>
                </Border>

                <!-- Chat Messages -->
                <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="3" Background="#252525" BorderBrush="#0A2E5C" BorderThickness="1" Margin="0,0,0,10">
                    <ItemsControl x:Name="MessagesItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="5,3,5,3" Padding="10,6,10,6" HorizontalAlignment="{Binding Alignment}" MaxWidth="500" Background="{Binding BubbleColor}" CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Text}" Foreground="White" TextWrapping="Wrap" FontSize="13" LineHeight="18"/>
                                        <TextBlock Text="{Binding FormattedTime}" Foreground="#888888" FontSize="8" HorizontalAlignment="Right" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Typing Indicator -->
                <Border x:Name="TypingIndicator" Grid.Row="4" Background="#2D2D2D" CornerRadius="8" Padding="10" Margin="0,0,0,10" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🤖 Bot is typing" Foreground="#888888" FontSize="11"/>
                        <TextBlock x:Name="TypingDots" Text="..." Foreground="#00D4FF" FontSize="11" FontWeight="Bold" Margin="5,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Input Area -->
                <Border Grid.Row="5" Background="#2D2D2D" CornerRadius="8" Padding="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="InputTextBox" Grid.Column="0" Background="#1E1E1E" Foreground="White" BorderBrush="#00D4FF" BorderThickness="1" Padding="10" FontSize="13" TextWrapping="Wrap" MinHeight="35" MaxHeight="80" VerticalScrollBarVisibility="Auto" IsEnabled="False" KeyDown="InputTextBox_KeyDown"/>

                        <Button x:Name="SendButton" Grid.Column="1" Content="📤" Width="40" Height="35" Margin="5,0,5,0" IsEnabled="False" Click="SendButton_Click" Background="#0A2E5C" Foreground="White" BorderBrush="#00D4FF" BorderThickness="1" Cursor="Hand"/>

                        <Button x:Name="HelpButton" Grid.Column="2" Content="❓" Width="40" Height="35" Margin="0,0,0,0" IsEnabled="False" Click="HelpButton_Click" Background="#1A5F7A" Foreground="White" BorderBrush="#00D4FF" BorderThickness="1" Cursor="Hand"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- RIGHT PANEL - Task & Quiz Area -->
        <Border Grid.Column="1" Grid.Row="0" Grid.RowSpan="3" Background="#1A1A1A" CornerRadius="10" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tab Buttons -->
                <Border Grid.Row="0" Background="#2D2D2D" CornerRadius="8" Padding="5" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="TasksTab" Content="📋 Tasks" Width="100" Height="30" Margin="3" Click="TasksTab_Click" Background="#0A2E5C" Foreground="White" BorderBrush="#00D4FF" BorderThickness="1" Cursor="Hand"/>
                        <Button x:Name="QuizTab" Content="🎯 Quiz" Width="100" Height="30" Margin="3" Click="QuizTab_Click" Background="#1A5F7A" Foreground="White" BorderBrush="#00D4FF" BorderThickness="1" Cursor="Hand"/>
                        <Button x:Name="ActivityTab" Content="📋 Log" Width="100" Height="30" Margin="3" Click="ActivityTab_Click" Background="#1A5F7A" Foreground="White" BorderBrush="#00D4FF" BorderThickness="1" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- Content Panel - Using Grid with StackPanels -->
                <Grid Grid.Row="1">
                    <!-- Tasks Panel -->
                    <StackPanel x:Name="TasksPanel" Visibility="Visible">
                        <!-- Add Task Section -->
                        <Border Background="#2D2D2D" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="➕ Add New Task" Foreground="#00D4FF" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                                <TextBox x:Name="TaskTitleBox" Background="#1E1E1E" Foreground="White" BorderBrush="#00D4FF" BorderThickness="1" Padding="8" FontSize="12" Margin="0,0,0,5" Text="Enter task title..."/>
                                <TextBox x:Name="TaskDescriptionBox" Background="#1E1E1E" Foreground="White" BorderBrush="#00D4FF" BorderThickness="1" Padding="8" FontSize="12" MinHeight="40" TextWrapping="Wrap" Margin="0,0,0,5" Text="Enter task description..."/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="TaskReminderBox" Background="#1E1E1E" Foreground="White" BorderBrush="#00D4FF" BorderThickness="1" Padding="8" FontSize="12" Width="120" Text="Reminder (days)..." Margin="0,0,5,0"/>
                                    <Button Content="➕ Add Task" Click="AddTaskButton_Click" Background="#1A5F7A" Foreground="White" BorderBrush="#00D4FF" BorderThickness="1" Padding="15,8" Cursor="Hand"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Task List -->
                        <Border Background="#2D2D2D" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock Text="📋 My Tasks" Foreground="#00D4FF" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                                <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="TasksListControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1A1A1A" CornerRadius="6" Padding="8" Margin="0,3,0,3">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="White" FontSize="12"/>
                                                            <TextBlock Text="{Binding Description}" Foreground="#888888" FontSize="10"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                <TextBlock Text="{Binding ReminderDisplay}" Foreground="#00D4FF" FontSize="9"/>
                                                                <TextBlock Text=" | " Foreground="#888888" FontSize="9"/>
                                                                <TextBlock Text="{Binding Status}" Foreground="White" FontSize="9"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <Button Grid.Column="1" Content="✅" Width="25" Height="25" Margin="5" Click="CompleteTask_Click" Tag="{Binding}" Background="Transparent" BorderThickness="0" FontSize="14" Cursor="Hand"/>
                                                        <Button Grid.Column="2" Content="🗑️" Width="25" Height="25" Margin="5" Click="DeleteTask_Click" Tag="{Binding}" Background="Transparent" BorderThickness="0" FontSize="14" Cursor="Hand"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <TextBlock x:Name="TaskCountLabel" Foreground="#888888" FontSize="10" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Quiz Panel -->
                    <StackPanel x:Name="QuizPanel" Visibility="Collapsed">
                        <Border Background="#2D2D2D" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock x:Name="QuizTitleText" Text="🎯 Cybersecurity Quiz" Foreground="#00D4FF" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                                <TextBlock x:Name="QuizProgressText" Text="Ready to test your knowledge?" Foreground="#888888" FontSize="12" Margin="0,0,0,10"/>

                                <Button x:Name="StartQuizButton" Content="🚀 Start Quiz" Click="StartQuizButton_Click" Background="#1A5F7A" Foreground="White" BorderBrush="#00D4FF" BorderThickness="1" Padding="20,10" FontSize="13" Cursor="Hand" Margin="0,0,0,15"/>

                                <Border x:Name="QuizQuestionPanel" Visibility="Collapsed" Background="#1E1E1E" CornerRadius="8" Padding="10">
                                    <StackPanel>
                                        <TextBlock x:Name="QuizQuestionText" Text="" Foreground="White" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,15"/>
                                        <ItemsControl x:Name="QuizOptionsControl">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding}" Click="QuizOption_Click" Background="#0A2E5C" Foreground="White" BorderBrush="#00D4FF" BorderThickness="1" Padding="10,8" Margin="0,3,0,3" Cursor="Hand" HorizontalAlignment="Stretch"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock x:Name="QuizFeedbackText" Text="" Foreground="#00D4FF" FontSize="12" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock x:Name="QuizCompleteText" Text="" Foreground="#00D4FF" FontSize="14" TextWrapping="Wrap" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Activity Log Panel -->
                    <StackPanel x:Name="ActivityPanel" Visibility="Collapsed">
                        <Border Background="#2D2D2D" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock Text="📋 Activity Log" Foreground="#00D4FF" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                                <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="ActivityLogControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1A1A1A" CornerRadius="6" Padding="8" Margin="0,3,0,3">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DisplayText}" Foreground="#CCCCCC" FontSize="11" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                    <Button Content="🔄 Refresh" Click="RefreshLogButton_Click" Background="#1A5F7A" Foreground="White" BorderBrush="#00D4FF" BorderThickness="1" Padding="15,8" Cursor="Hand" Margin="0,0,10,0"/>
                                    <Button Content="🗑️ Clear Log" Click="ClearLogButton_Click" Background="#8B0000" Foreground="White" BorderBrush="#FF4444" BorderThickness="1" Padding="15,8" Cursor="Hand"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>